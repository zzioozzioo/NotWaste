<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 상단 타이틀 -->
    <TextView
        android:id="@+id/tvTitle"
        android:text="냉장고 관리"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- 탭 메뉴 -->
    <LinearLayout
        android:id="@+id/layoutTabs"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFridge"
            android:text="냉장"
            android:textSize="16sp"
            android:backgroundTint="@color/light_gray"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="50dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFreeze"
            android:text="냉동"
            android:textSize="16sp"
            android:backgroundTint="@color/light_gray"
            android:layout_marginStart="8dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="50dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRoom"
            android:text="실온"
            android:textSize="16sp"
            android:backgroundTint="@color/light_gray"
            android:layout_marginStart="8dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="50dp"/>
    </LinearLayout>

    <!-- 식재료 목록 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerIngredients"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- 식재료 추가 버튼 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddIngredient"
        android:text="＋ 식재료 추가"
        android:textSize="18sp"
        android:backgroundTint="@color/very_dark_gray"
        android:layout_marginTop="20dp"
        android:layout_width="match_parent"
        android:layout_height="60dp"/>

    <include layout="@layout/view_bottom_nav"/>

</LinearLayout>
