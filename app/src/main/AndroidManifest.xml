<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.notwaste"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NotWaste">

        <activity android:name=".ui.home.HomeActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.add.AddIngredientActivity" />
        <activity android:name=".ui.fridge.FridgeActivity"/>
        <activity android:name=".ui.fridge.IngredientDetailActivity"/>
        <activity android:name=".ui.recipe.RecipeWebViewActivity" />
        <activity android:name=".ui.notification.NotificationActivity" />
        <activity android:name=".ui.notification.NotificationSettingActivity" />
        <activity android:name=".ui.mypage.MyPageActivity"/>
        <activity android:name=".ui.mypage.WasteIngredientActivity"/>



        <receiver
            android:name=".receiver.ExpireAlarmReceiver"
            android:exported="false" />
    </application>

</manifest>